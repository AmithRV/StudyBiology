<!-- Top Banner -->
<div class="bg-[#d1e1f9] py-4 px-4 text-center overflow-hidden">
  Don’t rely on guesswork —
  <span class="text-[#0525f2] font-medium">
    master Biology the smart and easy way
  </span>
</div>

<!-- Contact Section -->
<section class="bg-[#F0F8FF] overflow-hidden" id="contact-us">
  <div class="flex flex-col lg:flex-row">
    <!-- Left Image with Overlay -->
    <div class="relative w-full lg:w-1/2 h-[400px] md:h-[700px]">
      <img
        src="https://t4.ftcdn.net/jpg/03/18/40/09/360_F_318400976_8xA8EmS76mI0wZKP9gF0H9h4DDYO7CI6.jpg"
        alt="Contact Visual"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-[#004BB8]/40"></div>
    </div>

    <!-- Right Contact Form with AOS Animation -->
    <div
      class="w-full lg:w-1/2 px-6 py-12 lg:p-16 flex flex-col justify-center"
      data-aos="fade-left"
      data-aos-duration="1000"
      data-aos-delay="100"
    >
      <h2 class="text-4xl font-bold text-gray-900 mb-4">Contact Us</h2>
      <p class="text-gray-600 mb-8 text-base leading-relaxed">
        Have questions or need help with your study plan? Reach out to our team
        and we’ll assist you right away.
      </p>

      <form class="space-y-6" id="contactForm">
        <div>
          <label
            for="name"
            class="block text-sm font-medium text-gray-700 mb-1"
          >
            Full Name
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full border border-gray-300 rounded px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#004BB8]"
            placeholder="Enter your full name"
          />
        </div>

        <div>
          <label
            for="email"
            class="block text-sm font-medium text-gray-700 mb-1"
          >
            Email Address
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full border border-gray-300 rounded px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#004BB8]"
            placeholder="Enter your email"
          />
        </div>

        <div>
          <label
            for="message"
            class="block text-sm font-medium text-gray-700 mb-1"
          >
            Message
          </label>
          <textarea
            id="message"
            name="message"
            rows="4"
            required
            class="w-full border border-gray-300 rounded px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#004BB8]"
            placeholder="Type your message here..."></textarea>
        </div>

        <button
          type="submit"
          id="send-message"
          class="bg-[#004BB8] text-white font-semibold px-6 py-3 rounded hover:bg-[#005bbb] transition cursor-pointer"
        >
          Send Message
        </button>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  const form = document.getElementById('contactForm');
  const btn = document.getElementById('send-message');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    btn.disabled = true;
    const originalText = btn.innerText;
    btn.innerText = 'Sending...';

    const formData = new FormData(form);

    const data = {
      name: formData.get('name'),
      email: formData.get('email'),
      message: formData.get('message'),
    };

    try {
      const res = await fetch(
        'https://studybiology-admin.vercel.app/api/messages/send-message',
        {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data),
        },
      );

      const result = await res.json();

      if (res.ok) {
        alert('Message sent successfully!');
      } else {
        alert(result?.message || 'Something went wrong');
      }

      // Re-enable button + restore text
      btn.disabled = false;
      btn.innerText = originalText;

      form.reset();
    } catch (error) {
      alert('Network error. Please try again.');

      // Make sure button gets re-enabled even if error happens
      if (btn) {
        btn.disabled = false;
        btn.innerText = originalText;
      }
    }
  });
</script>
